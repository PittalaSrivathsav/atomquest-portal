# =============================================================================
# ATOMQUEST Portal — Environment variables
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Validate locally:
#   npm run env:check
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Public base URL (redirects, metadata). Defaults to http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "true" to silence startup env warnings (CI or partial local setup)
SKIP_ENV_VALIDATION=false

# -----------------------------------------------------------------------------
# MongoDB Atlas
# https://www.mongodb.com/docs/atlas/getting-started/
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/atomquest?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# Firebase — Client (public, embedded in the browser bundle)
# Console → Project settings → Your apps → Web app
# Enable Authentication → Email/Password and Google sign-in methods
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# -----------------------------------------------------------------------------
# Firebase — Admin (server only — NEVER commit real values)
# Console → Project settings → Service accounts → Generate new private key
#
# FIREBASE_ADMIN_PRIVATE_KEY tips:
# - Wrap in double quotes
# - Use literal \n for line breaks, OR paste multiline inside quotes
# -----------------------------------------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
